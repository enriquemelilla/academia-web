<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
                             https://jakarta.ee/xml/ns/jakartaee/web-app_6_1.xsd"
         version="6.1">

    <display-name>Academia Web</display-name>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <servlet>
        <servlet-name>TestConnectionServlet</servlet-name>
        <servlet-class>com.ereyes.academiaweb.servlet.TestConnectionServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>TestConnectionServlet</servlet-name>
        <url-pattern>/test-connection</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.ereyes.academiaweb.servlet.LoginServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.ereyes.academiaweb.servlet.LogoutServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>CursoListServlet</servlet-name>
        <servlet-class>com.ereyes.academiaweb.servlet.curso.CursoListServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CursoListServlet</servlet-name>
        <url-pattern>/cursos</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CursoDetailServlet</servlet-name>
        <servlet-class>com.ereyes.academiaweb.servlet.curso.CursoDetailServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CursoDetailServlet</servlet-name>
        <url-pattern>/curso-detalle</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CursoFormServlet</servlet-name>
        <servlet-class>com.ereyes.academiaweb.servlet.curso.CursoFormServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CursoFormServlet</servlet-name>
        <url-pattern>/admin/curso-form</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CursoSaveServlet</servlet-name>
        <servlet-class>com.ereyes.academiaweb.servlet.curso.CursoSaveServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CursoSaveServlet</servlet-name>
        <url-pattern>/curso-save</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CursoDeleteServlet</servlet-name>
        <servlet-class>com.ereyes.academiaweb.servlet.curso.CursoDeleteServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CursoDeleteServlet</servlet-name>
        <url-pattern>/curso-delete</url-pattern>
    </servlet-mapping>


</web-app>